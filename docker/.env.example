# Copy to .env and fill in real values before starting

# ── Deployment mode ───────────────────────────────────────────────────────────
# VM / HTTP testing:
#   CADDY_DOMAIN=:80
#   APP_SESSION_COOKIE_SECURE=false
#
# Production (real domain + auto-HTTPS):
#   CADDY_DOMAIN=hallenbelegungsplan.hitzhofen.de
#   APP_SESSION_COOKIE_SECURE=true

CADDY_DOMAIN=:80
APP_SESSION_COOKIE_SECURE=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me

# ── Bootstrap admin (created once on first start) ────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@hitzhofen.de
BOOTSTRAP_ADMIN_PASSWORD=change_me

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
# Set to the URL users will see in their browser (used in password-reset links)
MAIL_BASE_URL=http://YOUR_VM_IP

QUARKUS_MAILER_HOST=smtp.yourprovider.de
QUARKUS_MAILER_PORT=587
QUARKUS_MAILER_USERNAME=noreply@hitzhofen.de
QUARKUS_MAILER_PASSWORD=change_me

# ── Backup ────────────────────────────────────────────────────────────────────
# Local directory on the main VPS where dumps are stored.
BACKUP_DIR=/opt/hallenbelegungsplan/backups

# How many days to keep dumps locally / on the remote VPS.
BACKUP_KEEP_DAYS_LOCAL=14
BACKUP_KEEP_DAYS_REMOTE=60

# Remote backup VPS. Leave BACKUP_REMOTE_HOST empty to skip remote transfer.
BACKUP_REMOTE_HOST=your-backup-vps.example.com
BACKUP_REMOTE_USER=backup
BACKUP_REMOTE_DIR=/backups/hallenbelegungsplan

# SSH private key used to connect to the backup VPS (public key must be in
# backup user's authorized_keys on the remote).
BACKUP_SSH_KEY=/root/.ssh/backup_ed25519

# These rarely need changing (match docker-compose.yml defaults).
BACKUP_DB_CONTAINER=hallen-db
BACKUP_DB_NAME=hallen
BACKUP_DB_USER=hallen

# ── Grafana ───────────────────────────────────────────────────────────────────
# Access only via SSH tunnel: ssh -L 3000:127.0.0.1:3000 user@your-vps
# Then open http://localhost:3000 in your browser.
GRAFANA_ADMIN_PASSWORD=change_me
