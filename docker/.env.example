# Copy to .env and fill in real values before starting

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by both the db container and Quarkus (must match)
DB_PASSWORD=change_me

# ── Bootstrap admin (created once on first start) ────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@hitzhofen.de
BOOTSTRAP_ADMIN_PASSWORD=change_me

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
QUARKUS_MAILER_HOST=smtp.yourprovider.de
QUARKUS_MAILER_PORT=587
QUARKUS_MAILER_USERNAME=noreply@hitzhofen.de
QUARKUS_MAILER_PASSWORD=change_me
