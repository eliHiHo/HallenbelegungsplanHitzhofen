# CADDY_DOMAIN controls how Caddy binds:
#   VM / HTTP testing  →  CADDY_DOMAIN=:80
#   Production (HTTPS) →  CADDY_DOMAIN=hallenbelegungsplan.hitzhofen.de
#
# When a bare domain is used, Caddy automatically provisions TLS via ACME.
# When :80 is used, Caddy serves plain HTTP with no TLS attempt.
{$CADDY_DOMAIN} {

    # /api/* → Quarkus backend (prefix stripped before forwarding)
    # Browser:  GET /api/booking-requests
    # Backend:  GET /booking-requests
    handle_path /api/* {
        reverse_proxy backend:8080
    }

    # Everything else → React SPA (client-side routing via index.html fallback)
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}
